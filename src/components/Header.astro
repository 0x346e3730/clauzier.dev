---
import HeaderLink from "./HeaderLink.astro";
import DarkModeToggle from "./DarkModeToggle.astro";
---

<header>
  <a
    class="unset absolute z-10 left-[50%] -top-[100rem] translate-x-[-50%] bg-white text-black px-8 py-2 focus:top-[initial]"
    href="#main"
  >
    Skip to content
  </a>
  <nav>
    <section class="text-text-bold">
      <ul class="unset flex gap-4 [&>li]:p-0">
        <li><HeaderLink href="/">Home</HeaderLink></li>
        <li><HeaderLink href="/blog">Blog</HeaderLink></li>
      </ul>
    </section>
  </nav>
  <div
    class="max-[525px]:hidden justify-self-end py-2 flex items-center content-center text-text-bold"
  >
    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://twitter.com/0x346e3730"
    >
      <i
        class="fa-brands fa-twitter"
        aria-hidden="true"
        title="Twitter"></i>
      <span class="fa-sr-only">Twitter</span>
    </a>

    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://discord.gg/gwwdAJWqST"
    >
      <i
        class="fa-brands fa-discord"
        aria-hidden="true"
        title="Discord"></i>
      <span class="fa-sr-only">Discord</span>
    </a>
    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://github.com/0x346e3730"
    >
      <i
        class="fa-brands fa-github"
        aria-hidden="true"
        title="GitHub"></i>
      <span class="fa-sr-only">GitHub</span>
    </a>

    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://linkedin.com/in/0x346e3730"
    >
      <i
        class="fa-brands fa-linkedin"
        aria-hidden="true"
        title="LinkedIn"></i>
      <span class="fa-sr-only">LinkedIn</span>
    </a>

    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://instagram.com/0x346e3730"
    >
      <i
        class="fa-brands fa-instagram"
        aria-hidden="true"
        title="Instagram"></i>
      <span class="fa-sr-only">Instagram</span>
    </a>

    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://twitch.tv/0x346e3730"
    >
      <i
        class="fa-brands fa-twitch"
        aria-hidden="true"
        title="Twitch"></i>
      <span class="fa-sr-only">Twitch</span>
    </a>
  </div>
  <DarkModeToggle />
</header>
<style>
  header {
    grid-area: header;
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, 1fr) minmax(0, max-content) minmax(
        0,
        max-content
      );
  }
</style>
